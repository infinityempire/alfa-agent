# Alfa-Agent Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# WARMUP MODE (Browser Automation)
# Requires ONLY these credentials - no Reddit API keys needed!
# ===========================================
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Gemini API Key (optional - for AI-generated comments in warmup)
# If not provided, warmup uses pre-written casual comments
GEMINI_API_KEY=your_gemini_api_key

# ===========================================
# LEGACY Reddit API Credentials (not required for warmup mode)
# These were previously required for PRAW-based posting
# Create a Reddit app at: https://www.reddit.com/prefs/apps
# ===========================================
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=your_app_name_v1.0 (by u/your_username)

# Application Settings
DRY_RUN=true
LOG_LEVEL=INFO
